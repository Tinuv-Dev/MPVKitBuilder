     sources += files('video/out/vulkan/context_mac.m')
 endif
 
+# iOS/tvOS Vulkan (MoltenVK) windowing context. Unlike the macOS context it
+# does not need cocoa/swift: it creates the surface straight from the host
+# CAMetalLayer passed via --wid, so it only requires vulkan on a darwin target.
+ios_vulkan = get_option('ios-vulkan').require(
+    darwin and features['vulkan'] and not features['cocoa'],
+    error_message: 'vulkan was not found or this is a cocoa (macOS) build',
+)
+features += {'ios-vulkan': ios_vulkan.allowed()}
+if features['ios-vulkan']
+    sources += files('video/out/vulkan/context_ios.m')
+endif
+
 macos_media_player = get_option('macos-media-player').require(
     features['swift'],
     error_message: 'Swift was not found!',
