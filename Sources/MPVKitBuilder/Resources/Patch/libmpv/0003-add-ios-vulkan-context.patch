+
+// iOS/tvOS Vulkan (MoltenVK) windowing context.
+//
+// Unlike the macOS context (context_mac.m) this backend does not own a window
+// and does not depend on AppKit/Cocoa or the Swift MacCommon helper. The host
+// application embeds mpv by passing a CAMetalLayer pointer through --wid; we
+// create the Vulkan surface directly from that layer via VK_EXT_metal_surface.
+// The layer is owned by the host (its lifetime is guaranteed for the duration
+// of the context, and detached by setting --wid to 0), so it is not retained.
+
+#import <QuartzCore/QuartzCore.h>
+
+#include <vulkan/vulkan.h>
+#include <vulkan/vulkan_metal.h>
+
+#include "options/options.h"
+#include "video/out/gpu/context.h"
+
+#include "common.h"
+#include "context.h"
+#include "utils.h"
+
+struct priv {
+    struct mpvk_ctx vk;
+    CAMetalLayer *layer; // host-owned, not retained
+};
+
+static CAMetalLayer *ios_vk_get_layer(struct ra_ctx *ctx)
+{
+    int64_t wid = ctx->vo->opts->WinID;
+    if (wid == 0 || wid == -1)
+        return NULL;
+    id obj = (id)(intptr_t)wid;
+    if (![obj isKindOfClass:[CAMetalLayer class]])
+        return NULL;
+    return (CAMetalLayer *)obj;
+}
+
+static void ios_vk_get_pixel_size(CAMetalLayer *layer, int *w, int *h)
+{
+    CGSize size = layer.drawableSize;
+    if (size.width < 1 || size.height < 1) {
+        CGFloat scale = layer.contentsScale > 0 ? layer.contentsScale : 1;
+        size = layer.bounds.size;
+        size.width *= scale;
+        size.height *= scale;
+    }
+    *w = MPMAX((int)size.width, 1);
+    *h = MPMAX((int)size.height, 1);
+}
+
+static void ios_vk_uninit(struct ra_ctx *ctx)
+{
+    struct priv *p = ctx->priv;
+    ra_vk_ctx_uninit(ctx);
+    mpvk_uninit(&p->vk);
+}
+
+static bool ios_vk_init(struct ra_ctx *ctx)
+{
+    struct priv *p = ctx->priv = talloc_zero(ctx, struct priv);
+    struct mpvk_ctx *vk = &p->vk;
+    int msgl = ctx->opts.probing ? MSGL_V : MSGL_ERR;
+
+    p->layer = ios_vk_get_layer(ctx);
+    if (!p->layer) {
+        MP_MSG(ctx, msgl, "No CAMetalLayer was passed via --wid.\n");
+        goto error;
+    }
+
+    if (!mpvk_init(vk, ctx, VK_EXT_METAL_SURFACE_EXTENSION_NAME))
+        goto error;
+
+    VkMetalSurfaceCreateInfoEXT metal_info = {
+        .sType = VK_STRUCTURE_TYPE_METAL_SURFACE_CREATE_INFO_EXT,
+        .pNext = NULL,
+        .flags = 0,
+        .pLayer = p->layer,
+    };
+
+    struct ra_ctx_params params = {0};
+
+    VkInstance inst = vk->vkinst->instance;
+    VkResult res = vkCreateMetalSurfaceEXT(inst, &metal_info, NULL, &vk->surface);
+    if (res != VK_SUCCESS) {
+        MP_MSG(ctx, msgl, "Failed creating Metal surface\n");
+        goto error;
+    }
+
+    if (!ra_vk_ctx_init(ctx, vk, params, VK_PRESENT_MODE_FIFO_KHR))
+        goto error;
+
+    return true;
+error:
+    ios_vk_uninit(ctx);
+    return false;
+}
+
+static bool ios_vk_reconfig(struct ra_ctx *ctx)
+{
+    struct priv *p = ctx->priv;
+
+    p->layer = ios_vk_get_layer(ctx);
+    if (!p->layer)
+        return false;
+
+    int w, h;
+    ios_vk_get_pixel_size(p->layer, &w, &h);
+    return ra_vk_ctx_resize(ctx, w, h);
+}
+
+static int ios_vk_control(struct ra_ctx *ctx, int *events, int request, void *arg)
+{
+    return VO_NOTIMPL;
+}
+
+const struct ra_ctx_fns ra_ctx_vulkan_ios = {
+    .type           = "vulkan",
+    .name           = "iosvk",
+    .description    = "iOS/tvOS (Metal/MoltenVK)",
+    .reconfig       = ios_vk_reconfig,
+    .control        = ios_vk_control,
+    .init           = ios_vk_init,
+    .uninit         = ios_vk_uninit,
+};
