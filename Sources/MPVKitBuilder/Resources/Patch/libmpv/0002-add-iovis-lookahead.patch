diff --git a/demux/iovis_ahead_package.c b/demux/iovis_ahead_package.c
new file mode 100644
index 0000000..a105463
--- /dev/null
+++ b/demux/iovis_ahead_package.c
@@ -0,0 +1,64 @@
+/*
+ * iovis ahead-package-tap (Path D) - see iovis_lookahead.h for the contract.
+ *
+ * Emits the compressed audio packet plus codec params at the demuxer read-ahead
+ * frontier; the consumer decodes. Runs on the demux thread while the demux lock
+ * is held - the callback MUST be cheap and MUST NOT block or re-enter mpv.
+ *
+ * Read-only with respect to mpv's demuxer: never mutates packets/queue. No effect
+ * unless a callback is registered (single atomic load early-out).
+ */
+#include <stdatomic.h>
+#include <stddef.h>
+#include <stdlib.h>
+
+#include "iovis_lookahead.h"
+#include "iovis_lookahead_internal.h"
+#include "demux/demux.h"
+#include "demux/packet.h"
+#include "demux/stheader.h"
+
+// (cb, user) published as one immutable unit so feed never sees a torn pair
+// (old cb + new/NULL user). File-private storage type; not a public symbol.
+struct iovis_la_reg { iovis_la_callback cb; void *user; };
+static _Atomic(struct iovis_la_reg *) g_pkt_reg = NULL;
+
+void iovis_lookahead_set_callback(iovis_la_callback cb, void *user)
+{
+    struct iovis_la_reg *next = NULL;
+    if (cb) {
+        next = malloc(sizeof(*next));
+        if (!next)
+            return;     // allocation failed: keep the current registration
+        next->cb = cb;
+        next->user = user;
+    }
+    // The old reg is intentionally NOT freed: feed() may be reading it right now
+    // on the demux thread, and there is no join barrier here. set_callback is
+    // called rarely (register once / unregister once), so leaking ~16 bytes per
+    // switch avoids a use-after-free without locking the demux-locked hot path.
+    atomic_exchange(&g_pkt_reg, next);
+}
+
+void iovis_ahead_package_feed(struct sh_stream *sh, struct demux_packet *dp,
+                              struct demuxer *demuxer)
+{
+    struct iovis_la_reg *reg = atomic_load(&g_pkt_reg);  // one load -> paired cb+user
+    if (!reg)
+        return;
+    // Segmented packets (ordered chapters / EDL) carry their own codec params in
+    // dp->codec; fall back to the stream's codec only when not segmented.
+    struct mp_codec_params *c = (dp->segmented && dp->codec) ? dp->codec : sh->codec;
+    struct iovis_la_packet pkt = {
+        .data       = dp->buffer,
+        .size       = (int)dp->len,
+        .pts        = dp->pts,
+        .dts        = dp->dts,
+        .keyframe   = dp->keyframe,
+        .codecpar   = c ? c->lav_codecpar : NULL,
+        .samplerate = c ? c->samplerate : 0,
+        .channels   = c ? c->channels.num : 0,
+        .opaque     = demuxer ? demuxer->global : NULL,  // per-instance token
+    };
+    reg->cb(reg->user, &pkt);   // cb and user are necessarily from the same pair
+}
diff --git a/demux/iovis_ahead_pcm.c b/demux/iovis_ahead_pcm.c
new file mode 100644
index 0000000..c1c590a
--- /dev/null
+++ b/demux/iovis_ahead_pcm.c
@@ -0,0 +1,255 @@
+/*
+ * iovis ahead-pcm-tap (Path A) - FROZEN / harm-reduced. See iovis_lookahead.h.
+ *
+ * Copies each selected-audio packet into a bounded queue; a dedicated worker
+ * thread decodes it with libavcodec and emits PCM frames, keeping decode off the
+ * demux thread so demuxing is never stalled. No effect unless a PCM callback is
+ * registered (single atomic load early-out in feed).
+ *
+ * Disposition: this path is frozen. Do not add features here (planar all-planes,
+ * multi-instance opaque, backpressure, etc. belong to ahead-package-tap). Only
+ * correctness bug fixes are allowed, keeping interface / fields / thread model /
+ * queue capacity unchanged. See the project's audio-tap engineering plan.
+ */
+#include <stdatomic.h>
+#include <stddef.h>
+#include <stdlib.h>
+#include <string.h>
+
+#include <libavcodec/avcodec.h>
+#include <libavutil/avutil.h>
+#include <libavutil/frame.h>
+#include <libavutil/mem.h>
+
+#include "iovis_lookahead.h"
+#include "iovis_lookahead_internal.h"
+#include "common/msg.h"
+#include "demux/demux.h"
+#include "demux/packet.h"
+#include "demux/stheader.h"
+#include "osdep/threads.h"
+
+#define IOVIS_LA_QUEUE_CAP 1024     // PoC backpressure: drop new packets past this
+
+struct la_node {
+    uint8_t *data;          // av_malloc'd: size + AV_INPUT_BUFFER_PADDING_SIZE
+    int size;
+    double pts;
+    struct la_node *next;
+};
+
+static atomic_bool g_pcm_active = false;    // hot-path fast check (feed)
+static bool g_started = false;              // sync primitives + worker created
+static mp_mutex g_lock;
+static mp_cond g_cond;
+static mp_thread g_thread;
+static bool g_run = false;                  // worker should keep running (g_lock)
+static struct la_node *g_head = NULL, *g_tail = NULL;   // queue (g_lock)
+static int g_count = 0;                                 // queue length (g_lock)
+static iovis_la_pcm_callback g_pcm_cb = NULL;           // (g_lock)
+static void *g_pcm_user = NULL;                         // (g_lock)
+static AVCodecParameters *g_par = NULL;                 // current track params (g_lock)
+static int g_par_gen = 0;                               // bumped when g_par changes (g_lock)
+static unsigned long g_drop_count = 0;                  // queue-full drops, diagnostics (g_lock)
+
+static void free_queue_locked(void)
+{
+    struct la_node *n = g_head;
+    while (n) {
+        struct la_node *nx = n->next;
+        av_free(n->data);
+        free(n);
+        n = nx;
+    }
+    g_head = g_tail = NULL;
+    g_count = 0;
+}
+
+static MP_THREAD_VOID pcm_worker(void *arg)
+{
+    (void)arg;
+    AVCodecContext *ctx = NULL;
+    int built_gen = -1;     // g_par generation the current ctx was built for
+    AVPacket *pkt = av_packet_alloc();
+    AVFrame *frame = av_frame_alloc();
+
+    mp_mutex_lock(&g_lock);
+    while (g_run) {
+        while (g_run && !g_head)
+            mp_cond_wait(&g_cond, &g_lock);
+        if (!g_run)
+            break;
+
+        struct la_node *n = g_head;
+        g_head = n->next;
+        if (!g_head)
+            g_tail = NULL;
+        g_count--;
+
+        // bug #1/#2: the track's codec params can change on a track switch. Rebuild
+        // the decoder when the generation changes instead of decoding with a stale
+        // codec. bug #3: mark the generation handled even on failure, so a failed
+        // open does not retry find_decoder/alloc on every packet of that track.
+        if (g_par && g_par_gen != built_gen) {
+            if (ctx)
+                avcodec_free_context(&ctx);
+            ctx = NULL;
+            built_gen = g_par_gen;
+            const AVCodec *dec = avcodec_find_decoder(g_par->codec_id);
+            if (dec) {
+                ctx = avcodec_alloc_context3(dec);
+                if (ctx && (avcodec_parameters_to_context(ctx, g_par) < 0 ||
+                            avcodec_open2(ctx, dec, NULL) < 0)) {
+                    avcodec_free_context(&ctx);
+                    ctx = NULL;
+                }
+            }
+        }
+        iovis_la_pcm_callback cb = g_pcm_cb;
+        void *user = g_pcm_user;
+        mp_mutex_unlock(&g_lock);
+
+        if (ctx && pkt && frame && cb) {
+            pkt->data = n->data;
+            pkt->size = n->size;
+            pkt->pts  = AV_NOPTS_VALUE;
+            pkt->dts  = AV_NOPTS_VALUE;
+            if (avcodec_send_packet(ctx, pkt) == 0) {
+                while (avcodec_receive_frame(ctx, frame) == 0) {
+                    struct iovis_la_pcm pcm = {
+                        .data       = frame->data[0],
+                        .samples    = frame->nb_samples,
+                        .channels   = frame->ch_layout.nb_channels,
+                        .samplerate = frame->sample_rate,
+                        .format     = frame->format,
+                        .pts        = n->pts,
+                    };
+                    cb(user, &pcm);
+                    av_frame_unref(frame);
+                }
+            }
+        }
+        av_free(n->data);
+        free(n);
+
+        mp_mutex_lock(&g_lock);
+    }
+    mp_mutex_unlock(&g_lock);
+
+    if (ctx)
+        avcodec_free_context(&ctx);
+    av_packet_free(&pkt);
+    av_frame_free(&frame);
+    MP_THREAD_RETURN();
+}
+
+void iovis_lookahead_set_pcm_callback(iovis_la_pcm_callback cb, void *user)
+{
+    if (cb) {
+        if (!g_started) {
+            mp_mutex_init(&g_lock);
+            mp_cond_init(&g_cond);
+            g_started = true;
+        }
+        mp_mutex_lock(&g_lock);
+        g_pcm_cb = cb;
+        g_pcm_user = user;
+        bool need_thread = !g_run;
+        if (need_thread)
+            g_run = true;
+        mp_mutex_unlock(&g_lock);
+
+        if (need_thread) {
+            if (mp_thread_create(&g_thread, pcm_worker, NULL) != 0) {
+                mp_mutex_lock(&g_lock);
+                g_run = false;
+                mp_mutex_unlock(&g_lock);
+                return;
+            }
+        }
+        atomic_store(&g_pcm_active, true);
+    } else {
+        atomic_store(&g_pcm_active, false);
+        if (!g_started)
+            return;
+        mp_mutex_lock(&g_lock);
+        bool was_running = g_run;
+        g_run = false;
+        g_pcm_cb = NULL;
+        g_pcm_user = NULL;
+        mp_cond_broadcast(&g_cond);
+        mp_mutex_unlock(&g_lock);
+
+        if (was_running)
+            mp_thread_join(g_thread);
+
+        mp_mutex_lock(&g_lock);
+        free_queue_locked();
+        if (g_par)
+            avcodec_parameters_free(&g_par);
+        mp_mutex_unlock(&g_lock);
+    }
+}
+
+void iovis_ahead_pcm_feed(struct sh_stream *sh, struct demux_packet *dp,
+                          struct demuxer *demuxer)
+{
+    if (!atomic_load(&g_pcm_active))
+        return;
+
+    mp_mutex_lock(&g_lock);
+    if (!g_run) {
+        mp_mutex_unlock(&g_lock);
+        return;
+    }
+    if (g_count >= IOVIS_LA_QUEUE_CAP) {
+        // bug #4: queue full -> drop the new packet (capacity unchanged). Count it
+        // and warn on the first drop and then once per CAP, so a lost transcription
+        // segment is observable instead of silently dropped.
+        unsigned long dropped = ++g_drop_count;
+        mp_mutex_unlock(&g_lock);
+        if (demuxer && (dropped == 1 || dropped % IOVIS_LA_QUEUE_CAP == 0))
+            MP_WARN(demuxer, "[iovis_ahead_pcm] queue full (cap %d), dropped %lu packet(s) total\n",
+                    IOVIS_LA_QUEUE_CAP, dropped);
+        return;
+    }
+    // bug #1/#2: refresh codec params when the track's codec changes (compare
+    // codec_id + key params) and bump the generation so the worker rebuilds its
+    // decoder. Previously g_par was captured once and stuck on the first track.
+    // Segmented packets (ordered chapters / EDL) carry their own codec in
+    // dp->codec; fall back to the stream's codec only when not segmented.
+    struct mp_codec_params *sc = (dp->segmented && dp->codec) ? dp->codec : sh->codec;
+    AVCodecParameters *cp = sc ? sc->lav_codecpar : NULL;
+    if (cp && (!g_par ||
+               g_par->codec_id != cp->codec_id ||
+               g_par->sample_rate != cp->sample_rate ||
+               g_par->ch_layout.nb_channels != cp->ch_layout.nb_channels)) {
+        if (g_par)
+            avcodec_parameters_free(&g_par);
+        g_par = avcodec_parameters_alloc();
+        if (g_par)
+            avcodec_parameters_copy(g_par, cp);
+        g_par_gen++;
+    }
+    struct la_node *n = malloc(sizeof(*n));
+    if (n) {
+        n->data = av_malloc((size_t)dp->len + AV_INPUT_BUFFER_PADDING_SIZE);
+        if (n->data) {
+            memcpy(n->data, dp->buffer, dp->len);
+            memset(n->data + dp->len, 0, AV_INPUT_BUFFER_PADDING_SIZE);
+            n->size = (int)dp->len;
+            n->pts  = dp->pts;
+            n->next = NULL;
+            if (g_tail)
+                g_tail->next = n;
+            else
+                g_head = n;
+            g_tail = n;
+            g_count++;
+            mp_cond_signal(&g_cond);
+        } else {
+            free(n);
+        }
+    }
+    mp_mutex_unlock(&g_lock);
+}
diff --git a/demux/iovis_lookahead.c b/demux/iovis_lookahead.c
new file mode 100644
index 0000000..ad0d806
--- /dev/null
+++ b/demux/iovis_lookahead.c
@@ -0,0 +1,34 @@
+/*
+ * iovis look-ahead audio tap - shared demuxer entry. See iovis_lookahead.h for
+ * the public contract.
+ *
+ * The two consumption paths are implemented in separate translation units so the
+ * engineered package path and the frozen PCM path stay decoupled:
+ *   Path D (ahead-package-tap): iovis_ahead_package.c
+ *   Path A (ahead-pcm-tap, frozen): iovis_ahead_pcm.c
+ * This file only routes each selected-audio packet to both. Each path
+ * short-circuits on its own atomic active flag, so with no callback registered
+ * the entry costs one guard plus two single-atomic-load early-outs.
+ *
+ * Read-only with respect to mpv's demuxer: never mutates packets/queue, never
+ * advances the decoder reader_head.
+ */
+#include <stddef.h>
+
+#include "iovis_lookahead.h"
+#include "iovis_lookahead_internal.h"
+#include "demux/packet.h"
+#include "demux/stheader.h"
+
+void iovis_lookahead_feed(struct sh_stream *sh, struct demux_packet *dp,
+                          struct demuxer *demuxer)
+{
+    // Skip cached packets and wrapped AVFrames: a wrapped-AVFrame packet's buffer
+    // is not a compressed bitstream (it aliases an AVFrame), so Path D would emit a
+    // bogus packet and Path A would feed garbage to avcodec_send_packet. This
+    // matches mpv's own disk-cache exclusion (!dp->is_wrapped_avframe).
+    if (!sh || !dp || dp->is_cached || dp->is_wrapped_avframe || !dp->buffer || dp->len == 0)
+        return;
+    iovis_ahead_package_feed(sh, dp, demuxer);
+    iovis_ahead_pcm_feed(sh, dp, demuxer);
+}
diff --git a/demux/iovis_lookahead_internal.h b/demux/iovis_lookahead_internal.h
new file mode 100644
index 0000000..b4e86ca
--- /dev/null
+++ b/demux/iovis_lookahead_internal.h
@@ -0,0 +1,30 @@
+/*
+ * iovis look-ahead - internal split interface (not a public header).
+ *
+ * The two ahead consumption paths live in separate translation units so the
+ * engineered package path (ahead-package-tap, iovis_ahead_package.c) and the
+ * frozen / harm-reduced PCM path (ahead-pcm-tap, iovis_ahead_pcm.c) can evolve
+ * without touching each other. The shared demuxer entry iovis_lookahead_feed()
+ * in iovis_lookahead.c routes each selected-audio packet to both.
+ *
+ * Each path's feed does its own atomic active-flag early-out, so a path with no
+ * callback registered returns after a single atomic load.
+ */
+#ifndef MP_IOVIS_LOOKAHEAD_INTERNAL_H
+#define MP_IOVIS_LOOKAHEAD_INTERNAL_H
+
+struct sh_stream;
+struct demux_packet;
+struct demuxer;
+
+// ahead-package-tap (Path D): emit compressed packet + codecpar; consumer decodes.
+// `demuxer` supplies the per-instance opaque token (demuxer->global).
+void iovis_ahead_package_feed(struct sh_stream *sh, struct demux_packet *dp,
+                              struct demuxer *demuxer);
+
+// ahead-pcm-tap (Path A, frozen): decode to PCM on a worker thread. `demuxer` is
+// used only for diagnostic logging (queue-full drops); the path carries no opaque.
+void iovis_ahead_pcm_feed(struct sh_stream *sh, struct demux_packet *dp,
+                          struct demuxer *demuxer);
+
+#endif
diff --git a/demux/iovis_lookahead.h b/demux/iovis_lookahead.h
new file mode 100644
index 0000000..cd0eaf9
--- /dev/null
+++ b/demux/iovis_lookahead.h
@@ -0,0 +1,97 @@
+/*
+ * iovis look-ahead audio tap (read-side, decode-ahead-of-playback).
+ *
+ * Hooks the demuxer's read-ahead frontier: every selected-audio packet mpv adds
+ * to its packet queue (which sits ahead of the decoder/playhead by up to
+ * --demuxer-readahead-secs) is handed out for pre-transcription. pts/dts are
+ * mpv-internal seconds and line up with the time-pos property.
+ *
+ * Two consumption paths, selected at runtime by which callback is registered:
+ *   Path D (packet): emit the compressed packet + codec params; consumer decodes.
+ *   Path A (pcm):    decode inside mpv on a worker thread; emit PCM frames.
+ *
+ * Default: off. With no callback registered this is a no-op and does not affect
+ * demuxing or playback.
+ *
+ * ==== Path D threading contract (READ THIS BEFORE WRITING A CALLBACK) ====
+ * The Path D callback runs ON MPV'S DEMUXER THREAD WHILE THE DEMUXER LOCK IS
+ * HELD. Anything the callback does is on the critical path of demuxing: if it
+ * blocks, the demuxer stalls and the read-ahead buffer drains until playback
+ * stutters. Therefore the callback MUST:
+ *   - NOT block (no I/O, no decode, no malloc-heavy work, no waiting on locks
+ *     that another thread can hold across a blocking op);
+ *   - NOT call back into any mpv / libmpv API (re-entrancy => deadlock);
+ *   - return as fast as possible.
+ * The required consumer pattern is a ring buffer: inside the callback only
+ * memcpy the compressed bytes + a small codecpar summary into a lock-free /
+ * bounded queue and return immediately; do all decoding on the OTHER end of
+ * that queue, on your own thread. Do not decode inside the callback.
+ * (Path A's PCM callback instead runs on a dedicated worker thread - not the
+ * demux thread - and is not bound by this contract.)
+ */
+#ifndef MP_IOVIS_LOOKAHEAD_H
+#define MP_IOVIS_LOOKAHEAD_H
+
+#include <stdbool.h>
+#include <stdint.h>
+
+struct sh_stream;
+struct demux_packet;
+struct demuxer;
+struct AVCodecParameters;
+
+// ---- Path D: compressed packet out, consumer decodes ----
+struct iovis_la_packet {
+    const uint8_t *data;                // compressed bytes (this packet only)
+    int size;                           // bytes in data
+    double pts;                         // seconds, mpv time (== time-pos); may be MP_NOPTS_VALUE
+    double dts;                         // seconds; may be MP_NOPTS_VALUE
+    bool keyframe;
+    // FFmpeg decoder params for the packet's track. LIFETIME = TRACK: this points
+    // at mpv's own codecpar and is only valid for the duration of the callback,
+    // and only while the current audio track is selected. If you retain it past
+    // the callback you MUST avcodec_parameters_copy() it. On a track switch mpv
+    // keeps NO decoder state for you: codecpar changes (codec_id / sample_rate /
+    // channels) and the consumer must detect the change and rebuild its decoder.
+    struct AVCodecParameters *codecpar;
+    int samplerate;
+    int channels;
+    void *opaque;                       // per-instance token (== iovis_instance_token of the
+                                        // owning mpv handle, i.e. demuxer->global); lets one
+                                        // process-wide callback route packets from multiple
+                                        // demuxers/players (PiP/multi-player).
+};
+typedef void (*iovis_la_callback)(void *user, const struct iovis_la_packet *pkt);
+// Process-wide registration. Pass cb=NULL to disable.
+//
+// Lifecycle contract: `user` and `cb` must stay valid for the duration of every
+// in-flight callback. (cb, user) are published atomically as one pair, so a
+// callback always sees the user it was registered with - never a mismatched or
+// NULL user. But this setter does NOT join in-flight callbacks: after
+// set_callback(NULL, NULL) returns, at most one more already-dispatched call
+// (with its own original, self-consistent user) may still be running on the
+// demux thread. Before freeing anything `user` points at, the consumer must
+// ensure no callback is in flight (e.g. defer the free, or keep user alive for
+// the demuxer's lifetime).
+void iovis_lookahead_set_callback(iovis_la_callback cb, void *user);
+
+// ---- Path A: decode in mpv, PCM out ----
+// format is an AVSampleFormat (consumer links libavutil). For planar formats
+// data is plane 0 only (first cut). pts is mpv seconds (== time-pos).
+struct iovis_la_pcm {
+    const uint8_t *data;                // plane 0 / interleaved buffer
+    int samples;                        // samples per channel
+    int channels;
+    int samplerate;
+    int format;                         // enum AVSampleFormat
+    double pts;                         // seconds (== time-pos); may be MP_NOPTS_VALUE
+};
+typedef void (*iovis_la_pcm_callback)(void *user, const struct iovis_la_pcm *pcm);
+void iovis_lookahead_set_pcm_callback(iovis_la_pcm_callback cb, void *user);
+
+// Internal: called by demux.c for each selected-audio packet at the readahead
+// frontier. `demuxer` is the owning demuxer (for the per-instance opaque token).
+void iovis_lookahead_feed(struct sh_stream *sh, struct demux_packet *dp,
+                          struct demuxer *demuxer);
+
+#endif
diff --git a/meson.build b/meson.build
index fb10be5..ac42544 100644
--- a/meson.build
+++ b/meson.build
@@ -579,6 +579,20 @@ features += {'vector': cc.has_function_attribute('vector_size', required: get_op
 
 sources += path_source + timer_source
 
+# Iovis lookahead audio tap (demux). The shared entry plus the two split paths
+# (ahead-package-tap, ahead-pcm-tap) compile as one feature gated by
+# -Diovis_lookahead so the whole tap can be compiled out for compliance audit /
+# lean builds; the Apple builder opts in. Default disabled keeps stock builds clean.
+# When enabled, define HAVE_IOVIS_LOOKAHEAD project-wide so the call site in
+# demux.c is compiled in too. Disabled => the call site and the symbols both
+# vanish, so a stock build links clean (no undefined iovis_lookahead_feed).
+if get_option('iovis_lookahead').allowed()
+    sources += files('demux/iovis_lookahead.c',
+                     'demux/iovis_ahead_package.c',
+                     'demux/iovis_ahead_pcm.c')
+    add_project_arguments('-DHAVE_IOVIS_LOOKAHEAD', language: 'c')
+endif
+
 
 # various file generations
 tools_directory = join_paths(source_root, 'TOOLS')
