diff --git a/audio/out/iovis_tap.c b/audio/out/iovis_tap.c
new file mode 100644
index 0000000..448b48c
--- /dev/null
+++ b/audio/out/iovis_tap.c
@@ -0,0 +1,81 @@
+/*
+ * iovis PCM tap - see iovis_tap.h.
+ *
+ * If a consumer registers a callback, hand it the PCM chunk on mpv's audio pull
+ * thread. With no callback registered this function does nothing (one atomic
+ * load early-out) - no log, no accumulation, no allocation. An opt-in throttled
+ * diagnostic log is available for debugging, compiled in only with
+ * -Diovis_tap_log=enabled (default off, so production builds stay silent).
+ */
+
+#include <stdatomic.h>
+#ifdef IOVIS_TAP_LOG
+#include <inttypes.h>
+#endif
+
+#include "audio/out/iovis_tap.h"
+#include "audio/out/internal.h"
+#include "audio/format.h"
+#include "common/msg.h"
+
+// Declared in player/client.h (internal API, see line "mp_client_get_global").
+// Declared locally so the audio-path tap need not pull the whole client header
+// in. Returns the process-unique mpv_global* behind a client handle, which is
+// the same pointer stored in ao->global / demuxer->global for that instance.
+struct mpv_global *mp_client_get_global(struct mpv_handle *handle);
+
+static _Atomic(iovis_tap_callback) g_cb = NULL;
+static _Atomic(void *) g_user = NULL;
+
+void iovis_tap_set_callback(iovis_tap_callback cb, void *user)
+{
+    atomic_store(&g_user, user);
+    atomic_store(&g_cb, cb);
+}
+
+void *iovis_instance_token(struct mpv_handle *handle)
+{
+    return handle ? (void *)mp_client_get_global(handle) : NULL;
+}
+
+void iovis_tap_feed(struct ao *ao, void **data, int samples, int64_t out_time_ns,
+                    double stream_pts)
+{
+    if (!ao || !data || !data[0] || samples <= 0)
+        return;
+
+    iovis_tap_callback cb = atomic_load(&g_cb);
+    if (!cb) {
+#ifdef IOVIS_TAP_LOG
+        // Opt-in diagnostic only (-Diovis_tap_log=enabled). Throttle to ~one
+        // line per second of audio so the pipe is observable without a consumer.
+        static _Atomic(int64_t) acc;
+        int64_t n = atomic_fetch_add(&acc, samples) + samples;
+        if (ao->samplerate > 0 && n >= ao->samplerate) {
+            atomic_store(&acc, 0);
+            MP_INFO(ao, "[iovis_tap] pcm flowing: %d frames, fmt=%s, rate=%d, ch=%d, "
+                    "planes=%d, pts_us=%" PRId64 ", pts_stream=%.3f\n",
+                    samples, af_fmt_to_str(ao->format), ao->samplerate,
+                    ao->channels.num, ao->num_planes, out_time_ns / 1000, stream_pts);
+        }
+#endif
+        return;
+    }
+
+    // No DSP here: expose the buffer as-is (all planes / full format) and let the
+    // consumer down-mix / resample. planes aliases mpv's per-plane data array and
+    // is valid only for the duration of this synchronous callback.
+    struct iovis_tap_chunk chunk = {
+        .data       = data[0],
+        .samples    = samples,
+        .channels   = ao->channels.num,
+        .samplerate = ao->samplerate,
+        .format     = ao->format,
+        .num_planes = ao->num_planes,
+        .planes     = (const void *const *)data,
+        .pts_us     = out_time_ns / 1000,
+        .pts_stream = stream_pts,
+        .opaque     = ao->global,   // per-instance token; matches iovis_instance_token
+    };
+    cb(atomic_load(&g_user), &chunk);
+}
diff --git a/audio/out/iovis_tap.h b/audio/out/iovis_tap.h
new file mode 100644
index 0000000..bc7787a
--- /dev/null
+++ b/audio/out/iovis_tap.h
@@ -0,0 +1,68 @@
+/*
+ * iovis PCM tap - non-invasive read-side tap on mpv's audio output path.
+ *
+ * This is an out-of-tree addition (not part of upstream mpv). It exposes the
+ * post-decode / post-filter PCM that mpv hands to a pull-based audio output
+ * (audiounit / coreaudio / avfoundation on Apple platforms), without changing
+ * playback behaviour. Default: off (no callback registered => no effect; the
+ * optional diagnostic log is compiled in only with -Diovis_tap_log=enabled).
+ */
+
+#ifndef MP_AO_IOVIS_TAP_H_
+#define MP_AO_IOVIS_TAP_H_
+
+#include <stdint.h>
+
+struct ao;
+struct mpv_handle;
+
+// One PCM chunk as handed to the audio output. The tap does NO DSP: it exposes
+// the buffer mpv just filled exactly as-is and leaves channel down-mix / resample
+// to the consumer (build the source AVAudioFormat from format+channels+num_planes
+// and convert with AVAudioConverter).
+//
+// `planes` holds num_planes plane pointers, valid ONLY for the duration of the
+// callback (copy out before returning):
+//   - interleaved / packed formats: num_planes == 1, planes[0] is the whole
+//     all-channel buffer.
+//   - planar formats: num_planes == channels, planes[i] is channel i.
+// `data` aliases planes[0] and is kept so a consumer that only wants plane 0
+// (e.g. a legacy mono path) need not touch the planes array.
+struct iovis_tap_chunk {
+    const void *data;           // == planes[0]
+    int samples;                // frames per channel actually filled with real data
+    int channels;
+    int samplerate;
+    int format;                 // AF_FORMAT_*
+    int num_planes;             // planar: == channels; interleaved/packed: 1
+    const void *const *planes;  // num_planes plane pointers; valid only during the callback
+    int64_t pts_us;             // device delay: out_time_ns/1000, time until the last
+                                // sample is audible (NOT a stream timestamp).
+    double pts_stream;          // stream-internal PTS in seconds of the first sample in
+                                // this chunk (same clock as the time-pos property), for
+                                // subtitle alignment; MP_NOPTS_VALUE (-0x1p+63) if unknown.
+    void *opaque;               // per-instance token (== iovis_instance_token of the
+                                // owning mpv handle); lets one process-wide callback
+                                // route chunks from multiple players (PiP/multi-player).
+};
+
+typedef void (*iovis_tap_callback)(void *user, const struct iovis_tap_chunk *chunk);
+
+// Process-wide, one-shot registration. The callback runs on mpv's audio pull
+// thread and MUST NOT block (copy out and return). Pass cb=NULL to disable.
+void iovis_tap_set_callback(iovis_tap_callback cb, void *user);
+
+// Process-unique token for the mpv instance behind `handle` (its mpv_global*).
+// The consumer calls this once per player to build an opaque -> player map; the
+// same token is delivered as iovis_tap_chunk.opaque and (Path D) as the
+// lookahead packet opaque, so both engineering taps share one instance identity.
+// Returns NULL for a NULL handle. Stable for the lifetime of the mpv instance.
+void *iovis_instance_token(struct mpv_handle *handle);
+
+// Internal: called by audio/out/buffer.c right after ao_read_data() filled the
+// caller's buffer. stream_pts is the stream-internal PTS (seconds) of the first
+// sample read, or MP_NOPTS_VALUE if unknown. Not part of any public client API.
+void iovis_tap_feed(struct ao *ao, void **data, int samples, int64_t out_time_ns,
+                    double stream_pts);
+
+#endif
diff --git a/meson.build b/meson.build
index fb10be5..fd8e92d 100644
--- a/meson.build
+++ b/meson.build
@@ -267,6 +267,18 @@ sources = files(
     'ta/ta_utils.c',
 )
 
+# Iovis realtime PCM tap (audio/out). Gated by -Diovis_tap so it can be
+# compiled out entirely for compliance audit / lean builds; the Apple builder
+# opts in. Default disabled keeps stock mpv builds unchanged.
+if get_option('iovis_tap').allowed()
+    sources += files('audio/out/iovis_tap.c')
+    # Opt-in diagnostic log (off in production). Lets the tap print a throttled
+    # line when no consumer is registered, for pipe debugging only.
+    if get_option('iovis_tap_log').allowed()
+        add_project_arguments('-DIOVIS_TAP_LOG', language: 'c')
+    endif
+endif
+
 
 # compiler stuff
 cc = meson.get_compiler('c')
